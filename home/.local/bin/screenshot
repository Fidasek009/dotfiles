#!/bin/sh
set -eu

screenshot_dir=${XDG_SCREENSHOTS_DIR:-"$HOME/Pictures/Screenshots"}

usage() {
	printf 'usage: screenshot {annotate|copy-region|copy-screen}\n' >&2
	exit 2
}

copy_region() {
	grim -g "$(slurp)" - | wl-copy --type image/png
}

copy_screen() {
	grim - | wl-copy --type image/png
}

annotate() {
	mkdir -p "$screenshot_dir"
	grim - | satty \
		--filename - \
		--fullscreen \
		--initial-tool crop \
		--copy-command 'wl-copy --type image/png' \
		--output-filename "$screenshot_dir/%Y%m%d_%H%M%S.png"
}

case "${1:-}" in
	annotate) annotate ;;
	copy-region) copy_region ;;
	copy-screen) copy_screen ;;
	*) usage ;;
esac
